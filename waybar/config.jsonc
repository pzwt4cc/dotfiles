{
    "output": "DP-2",
    "layer": "top",
    "position": "top",
    "height": 40,

    // Left
    "modules-left":   ["custom/arch", "custom/cpu", "custom/gpu", "memory", "hyprland/window"],
    // Center
    "modules-center": ["clock"],
    // Right
    "modules-right":  ["hyprland/workspaces", "tray", "bluetooth", "network", "pulseaudio", "custom/swaync", "custom/powermenu"],

    // LEFT SIDE
    "custom/arch": {
        "format": " َ°£‡ ",
        "tooltip": false,
        "on-click": "rofi -show drun"
    },

    "custom/cpu": {
        "exec": "temp=$(cat /sys/class/hwmon/hwmon*/temp*_input 2>/dev/null | head -n 1 | awk '{print int($1/1000)}'); usage=$(top -bn1 | grep 'Cpu(s)' | awk '{print int($2+$4)}'); echo \"CPU: ${temp}آ°C ${usage}%\"",
        "interval": 2,
        "format": " {} "
    },

    "custom/gpu": {
        "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu,memory.used --format=csv,noheader,nounits | awk -F', ' '{print \"GPU: \"$2\"آ°C \"$1\"% | VRAM: \"sprintf(\"%.1f\", $3/1024)\"GB\"}' 2>/dev/null || echo \"GPU: N/A\"",
        "interval": 2,
        "format": " {} "
    },

    "memory": {
        "format": " RAM: {used:0.0f}/{total:0.0f}G ",
        "interval": 2
    },

    "hyprland/window": {
        "format": " {title} ",
        "max-length": 40
    },

    // CENTER
    "clock": {
        "format": " {:%H:%M  |  %A, %b %d} ",
        "tooltip-format": "<tt><big>{calendar}</big></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "months":     "<span color='#ffffff'><b>{}</b></span>",
                "days":       "<span color='#dddddd'>{}</span>",
                "today":      "<span color='#f7768e'><b><u>{}</u></b></span>"
            }
        }
    },

    // RIGHT SIDE
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "persistent-workspaces": { "*": [1, 2, 3, 4, 5] },
        "format": "{icon}",
        "format-icons": {
            "default": "َ°ڈ–",
            "active": "َ°ڈ—"
        }
    },

    "tray": {
        "icon-size": 16,
        "spacing": 10
    },

    "bluetooth": {
        "format": " َ°‚¯ ",
        "format-connected": " َ°‚± ",
        "format-disabled": " َ°‚² ",
        "on-click": "blueman-manager"
    },

    "network": {
        "interval": 2,
        "format-wifi": " َ°¤¨ ",
        "format-ethernet": " َ°ˆ€ ",
        "format-linked": " َ°ˆ€ ",
        "format-disconnected": " َ°–ھ ",
        "tooltip-format": "{essid} ({signaldBm}dBm)\nَ°‡ڑ {bandwidthDownBytes}  َ°•’ {bandwidthUpBytes}",
        "on-click": "nm-connection-editor"
    },

    "pulseaudio": {
        "format": " {icon}  {volume}% ",
        "format-muted": " َ°‌ں  Muted ",
        "format-icons": {
            "headphone": "َ°‹‹",
            "hands-free": "َ°‹ژ",
            "headset": "َ°‹ژ",
            "phone": "َ°ڈ²",
            "portable": "َ°ڈ²",
            "car": "َ°„‹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol"
    },

    "custom/swaync": {
        "tooltip": true,
        "format": " {icon} ",
        "format-icons": {
            "notification": "َ°‚ڑ<span foreground='#f7768e'><sup>ï‘„</sup></span>",
            "none": "َ°‚ڑ",
            "dnd-notification": "َ°‚›<span foreground='#f7768e'><sup>ï‘„</sup></span>",
            "dnd-none": "َ°‚›",
            "inhibited-notification": "َ°‚ڑ<span foreground='#f7768e'><sup>ï‘„</sup></span>",
            "inhibited-none": "َ°‚ڑ",
            "dnd-inhibited-notification": "َ°‚›<span foreground='#f7768e'><sup>ï‘„</sup></span>",
            "dnd-inhibited-none": "َ°‚›"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "custom/powermenu": {
        "format": " َ°گ¥ ",
        "on-click": "wlogout -b 5",
        "tooltip": false
    }
}
