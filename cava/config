@include ~/.cache/wal/colors-cava

[general]
framerate = 60

[input]
method = pulse
source = auto

[output]
method = ncurses
style = classic
bar_width = 2
bar_spacing = 1

[color]
gradient = 1
gradient_count = 2
gradient_color_1 = color2
gradient_color_2 = color4

[smoothing]
noise_reduction = 60
monstercat = 1
waves = 0
gravity = 100